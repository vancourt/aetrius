{
  "name": "council-app",
  "version": "1.0.0",
  "type": "module",
  "description": "Multi-AI chat router via Playwright browser automation",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:vue": "vite",
    "dev:electron": "electron .",
    "dev": "concurrently \"npm run dev:vue\" \"npx wait-on file:.vite-port && npm run dev:electron\"",
    "build:vue": "vite build",
    "build": "npm run build:vue && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "marked": "^18.0.5",
    "pinia": "^2.1.7",
    "playwright": "^1.45.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.council.app",
    "productName": "Council App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ]
  }
}
